tent: space-between;\r\n  gap: 0.7rem;\r\n}\r\n\r\n.settings-toggle-list p {\r\n  margin: 0;\r\n  color: #1f2937;\r\n  font: 700 0.82rem/1.2 Inter, sans-serif;\r\n}\r\n\r\n.settings-toggle-list small {\r\n  color: #64748b;\r\n  font: 600 0.66rem/1.2 Inter, sans-serif;\r\n}\r\n\r\n.settings-toggle {\r\n  width: 42px;\r\n  height: 22px;\r\n  border-radius: 999px;\r\n  border: 0;\r\n  background: #dbe1ea;\r\n  position: relative;\r\n}\r\n\r\n.settings-toggle::after {\r\n  content: '';\r\n  position: absolute;\r\n  width: 16px;\r\n  height: 16px;\r\n  border-radius: 999px;\r\n  background: #ffffff;\r\n  left: 3px;\r\n  top: 3px;\r\n}\r\n\r\n.settings-toggle.on {\r\n  background: #88d982;\r\n}\r\n\r\n.settings-toggle.on::after {\r\n  left: 23px;\r\n}\r\n\r\n.settings-data-card {\r\n  display: grid;\r\n  gap: 0.6rem;\r\n}\r\n\r\n.settings-action-row {\r\n  border: 1px solid rgba(148, 163, 184, 0.2);\r\n  border-radius: 10px;\r\n  background: #f8fafc;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  gap: 0.6rem;\r\n  padding: 0.65rem 0.75rem;\r\n  color: #1f2937;\r\n  font: 700 0.78rem/1.2 Inter, sans-serif;\r\n}\r\n\r\n.settings-action-row span {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  gap: 0.4rem;\r\n}\r\n\r\n.settings-action-row i {\r\n  font-style: normal;\r\n  color: #64748b;\r\n  font-size: 1.05rem;\r\n}\r\n\r\n.settings-data-card small {\r\n  color: #64748b;\r\n  text-align: center;\r\n  font: 600 0.64rem/1.3 Inter, sans-serif;\r\n}\r\n\r\n.settings-footer-actions {\r\n  display: flex;\r\n  justify-content: end;\r\n  gap: 0.6rem;\r\n  padding-bottom: 0.8rem;\r\n}\r\n\r\n.settings-discard-btn {\r\n  border: 0;\r\n  background: transparent;\r\n  color: #526077;\r\n  font: 700 0.78rem/1 Inter, sans-serif;\r\n  padding: 0.45rem 0.6rem;\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n  .settings-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .settings-branding-layout {\r\n    grid-template-columns: 1fr;\r\n 